# ------------------------------------------------------------------
# Créatifia — environment variables
# Copy to .env (local) or set in Railway → Variables.
# ------------------------------------------------------------------

# Required ----------------------------------------------------------
# Postgres connection string. On Railway, add the Postgres plugin and
# reference its DATABASE_URL (Railway injects it automatically).
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Secret used to sign session cookies. Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Public URL of the deployed app (no trailing slash). Used for Stripe
# redirect URLs and email links.
APP_URL=https://creatifia.com

# Stripe (payments) ------------------------------------------------
# From the Stripe dashboard. Use test keys (sk_test_…) until going live.
STRIPE_SECRET_KEY=sk_test_xxx
# Create a recurring $299/month Price in Stripe → copy its id (price_…).
STRIPE_PRICE_ID=price_xxx
# From the Stripe webhook endpoint you create pointing at
#   {APP_URL}/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Brevo (transactional email) --------------------------------------
BREVO_API_KEY=
BREVO_SENDER_EMAIL=hello@creatifia.com
BREVO_SENDER_NAME=Créatifia
# Where new-lead / pipeline notifications are sent (your inbox).
ADMIN_NOTIFY_EMAIL=team@creatifia.com
